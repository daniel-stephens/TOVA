# docker/Dockerfile.ui
# syntax=docker/dockerfile:1.4
ARG ASSETS_IMAGE=tova-assets:dev
FROM ${ASSETS_IMAGE} AS static

FROM python:3.12-slim-bookworm AS builder
WORKDIR /app

# OS updates and build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gcc \
    g++ \
    pkg-config \
    libffi-dev \
    python3-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY ui/requirements.txt .
RUN pip install --upgrade pip && pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir gunicorn

# Copy UI code and templates
COPY templates /app/templates
COPY ui/ /app
# Shared Python package (imports like `tova.core`, `tova.api.models`, used by web views)
COPY src /app/src

# Copy shared static assets from the assets stage
COPY --from=static /static /app/static

ENV API_BASE_URL=http://api:11000
ENV PYTHONPATH=/app/src
EXPOSE 8080
# Django: migrate/collectstatic then WSGI (master uses gunicorn app:server for Flask)
CMD ["sh", "-c", "python manage.py migrate --noinput && python manage.py collectstatic --noinput && exec gunicorn -w 2 -b 0.0.0.0:8080 wsgi:application"]
